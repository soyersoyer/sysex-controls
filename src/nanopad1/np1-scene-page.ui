<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  <template class="Np1ScenePage" parent="KorgScenePage">
    <property name="title" translatable="yes">Scene</property>
    <property name="child">
      <object class="AdwToolbarView">
        <child type="top"><object class="AdwHeaderBar"/></child>
        <property name="content">
          <object class="ScPreferencesPage">

            <child>
              <object class="AdwPreferencesGroup">

                <child>
                  <object class="AdwEntryRow">
                    <child>
                      <object class="MmControl">
                        <property name="id">0x00</property>
                        <property name="size">12</property>
                      </object>
                    </child>
                    <property name="title" translatable="yes">Name</property>
                    <property name="show-apply-button">yes</property>
                  </object>
                </child>

              </object>
            </child>

            <child>
              <object class="AdwPreferencesGroup">

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">X-Y Pad</property>
                    <property name="control-id-offset">0x10</property>
                    <property name="target-page">Np1XyPadPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

              </object>
            </child>

            <child>
              <object class="AdwPreferencesGroup">

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Pad 1</property>
                    <property name="control-id-offset">0x20</property>
                    <property name="target-page">Np1PadPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Pad 2</property>
                    <property name="control-id-offset">0x30</property>
                    <property name="target-page">Np1PadPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Pad 3</property>
                    <property name="control-id-offset">0x40</property>
                    <property name="target-page">Np1PadPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Pad 4</property>
                    <property name="control-id-offset">0x50</property>
                    <property name="target-page">Np1PadPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Pad 5</property>
                    <property name="control-id-offset">0x60</property>
                    <property name="target-page">Np1PadPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Pad 6</property>
                    <property name="control-id-offset">0x70</property>
                    <property name="target-page">Np1PadPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

              </object>
            </child>

            <child>
              <object class="AdwPreferencesGroup">

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Pad 7</property>
                    <property name="control-id-offset">0x80</property>
                    <property name="target-page">Np1PadPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Pad 8</property>
                    <property name="control-id-offset">0x90</property>
                    <property name="target-page">Np1PadPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Pad 9</property>
                    <property name="control-id-offset">0xa0</property>
                    <property name="target-page">Np1PadPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Pad 10</property>
                    <property name="control-id-offset">0xb0</property>
                    <property name="target-page">Np1PadPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Pad 11</property>
                    <property name="control-id-offset">0xc0</property>
                    <property name="target-page">Np1PadPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Pad 12</property>
                    <property name="control-id-offset">0xd0</property>
                    <property name="target-page">Np1PadPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

              </object>
            </child>

          </object>
        </property>
      </object>
    </property>
  </template>
</interface>
