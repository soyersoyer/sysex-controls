<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  <template class="Np1PadPage" parent="ScNavigationPage">
    <property name="title" translatable="yes">Pad</property>
    <property name="child">
      <object class="AdwToolbarView">
        <child type="top"><object class="AdwHeaderBar"/></child>
        <property name="content">
          <object class="ScPreferencesPage">

            <child>
              <object class="AdwPreferencesGroup">

                <child>
                  <object class="ScChRowGlob">
                    <child><object class="MmControl"><property name="id">0x00</property></object></child>
                  </object>
                </child>

              </object>
            </child>

            <child>
              <object class="AdwPreferencesGroup">

                <child>
                  <object class="ScComboRow" id="control_mode">
                    <child><object class="MmControl"><property name="id">0x01</property></object></child>
                    <property name="title" translatable="yes">Mode</property>
                    <property name="model">
                      <object class="ScControlValueList">
                        <items>
                          <item>No Assign</item>
                          <item>CC</item>
                          <item>Note</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="ScComboRow">
                    <binding name="visible">
                      <closure type="gboolean" function="cv_in">
                        <lookup type="ScComboRow" name="selected-item">control_mode</lookup>
                        <constant type="GVariant">[0x01, 0x02]</constant>
                      </closure>
                    </binding>
                    <child><object class="MmControl"><property name="id">0x0a</property></object></child>
                    <property name="title" translatable="yes">Behavior</property>
                    <property name="model">
                      <object class="ScControlValueList">
                        <items>
                          <item>Momentary</item>
                          <item>Toggle</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="AdwSwitchRow">
                    <binding name="visible">
                      <closure type="gboolean" function="cv_in">
                        <lookup type="ScComboRow" name="selected-item">control_mode</lookup>
                        <constant type="GVariant">[0x01, 0x02]</constant>
                      </closure>
                    </binding>
                    <child><object class="MmControl"><property name="id">0x0d</property></object></child>
                    <property name="title" translatable="yes">Roll/Flam Enable</property>
                  </object>
                </child>

              </object>
            </child>

            <child>
              <object class="AdwPreferencesGroup">

                <binding name="visible">
                  <closure type="gboolean" function="cv_in">
                    <lookup type="ScComboRow" name="selected-item">control_mode</lookup>
                    <constant type="GVariant">[0x01]</constant>
                  </closure>
                </binding>

                <child>
                  <object class="ScCcRow">
                    <child><object class="MmControl"><property name="id">0x02</property></object></child>
                    <property name="title" translatable="yes">CC 1</property>
                  </object>
                </child>

                <child>
                  <object class="KorgCcNaRow">
                    <child><object class="MmControl"><property name="id">0x03</property></object></child>
                    <property name="title" translatable="yes">CC 2</property>
                  </object>
                </child>

                <child>
                  <object class="KorgCcNaRow">
                    <child><object class="MmControl"><property name="id">0x04</property></object></child>
                    <property name="title" translatable="yes">CC 3</property>
                  </object>
                </child>

                <child>
                  <object class="KorgCcNaRow">
                    <child><object class="MmControl"><property name="id">0x05</property></object></child>
                    <property name="title" translatable="yes">CC 4</property>
                  </object>
                </child>

                <child>
                  <object class="KorgCcNaRow">
                    <child><object class="MmControl"><property name="id">0x06</property></object></child>
                    <property name="title" translatable="yes">CC 5</property>
                  </object>
                </child>

                <child>
                  <object class="KorgCcNaRow">
                    <child><object class="MmControl"><property name="id">0x07</property></object></child>
                    <property name="title" translatable="yes">CC 6</property>
                  </object>
                </child>

                <child>
                  <object class="KorgCcNaRow">
                    <child><object class="MmControl"><property name="id">0x08</property></object></child>
                    <property name="title" translatable="yes">CC 7</property>
                  </object>
                </child>

                <child>
                  <object class="KorgCcNaRow">
                    <child><object class="MmControl"><property name="id">0x09</property></object></child>
                    <property name="title" translatable="yes">CC 8</property>
                  </object>
                </child>

              </object>
            </child>

            <child>
              <object class="AdwPreferencesGroup">

                <binding name="visible">
                  <closure type="gboolean" function="cv_in">
                    <lookup type="ScComboRow" name="selected-item">control_mode</lookup>
                    <constant type="GVariant">[0x01]</constant>
                  </closure>
                </binding>

                <child>
                  <object class="AdwSpinRow">
                    <child><object class="MmControl"><property name="id">0x0b</property></object></child>
                    <property name="title" translatable="yes">Min</property>
                    <property name="adjustment">
                      <object class="GtkAdjustment">
                        <property name="lower">0</property>
                        <property name="upper">127</property>
                        <property name="page-increment">10</property>
                        <property name="step-increment">1</property>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="AdwSpinRow">
                    <child><object class="MmControl"><property name="id">0x0c</property></object></child>
                    <property name="title" translatable="yes">Max</property>
                    <property name="adjustment">
                      <object class="GtkAdjustment">
                        <property name="lower">0</property>
                        <property name="upper">127</property>
                        <property name="page-increment">10</property>
                        <property name="step-increment">1</property>
                      </object>
                    </property>
                  </object>
                </child>

              </object>
            </child>

            <child>
              <object class="AdwPreferencesGroup">

                <binding name="visible">
                  <closure type="gboolean" function="cv_in">
                    <lookup type="ScComboRow" name="selected-item">control_mode</lookup>
                    <constant type="GVariant">[0x02]</constant>
                  </closure>
                </binding>

                <child>
                  <object class="ScNoteRow">
                    <child><object class="MmControl"><property name="id">0x02</property></object></child>
                    <property name="title" translatable="yes">Note 1</property>
                  </object>
                </child>

                <child>
                  <object class="KorgNoteNaRow">
                    <child><object class="MmControl"><property name="id">0x03</property></object></child>
                    <property name="title" translatable="yes">Note 2</property>
                  </object>
                </child>

                <child>
                  <object class="KorgNoteNaRow">
                    <child><object class="MmControl"><property name="id">0x04</property></object></child>
                    <property name="title" translatable="yes">Note 3</property>
                  </object>
                </child>

                <child>
                  <object class="KorgNoteNaRow">
                    <child><object class="MmControl"><property name="id">0x05</property></object></child>
                    <property name="title" translatable="yes">Note 4</property>
                  </object>
                </child>

                <child>
                  <object class="KorgNoteNaRow">
                    <child><object class="MmControl"><property name="id">0x06</property></object></child>
                    <property name="title" translatable="yes">Note 5</property>
                  </object>
                </child>

                <child>
                  <object class="KorgNoteNaRow">
                    <child><object class="MmControl"><property name="id">0x07</property></object></child>
                    <property name="title" translatable="yes">Note 6</property>
                  </object>
                </child>

                <child>
                  <object class="KorgNoteNaRow">
                    <child><object class="MmControl"><property name="id">0x08</property></object></child>
                    <property name="title" translatable="yes">Note 7</property>
                  </object>
                </child>

                <child>
                  <object class="KorgNoteNaRow">
                    <child><object class="MmControl"><property name="id">0x09</property></object></child>
                    <property name="title" translatable="yes">Note 8</property>
                  </object>
                </child>

              </object>
            </child>



          </object>
        </property>
      </object>
    </property>

  </template>
</interface>
