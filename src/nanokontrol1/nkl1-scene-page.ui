<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  <template class="Nkl1ScenePage" parent="KorgScenePage">
    <property name="title" translatable="yes">Scene</property>
    <property name="child">
      <object class="AdwToolbarView">
        <child type="top"><object class="AdwHeaderBar"/></child>
        <property name="content">
          <object class="ScPreferencesPage">

            <child>
              <object class="AdwPreferencesGroup">

                <child>
                  <object class="AdwEntryRow">
                    <child>
                      <object class="MmControl">
                        <property name="id">0x00</property>
                        <property name="size">12</property>
                      </object>
                    </child>
                    <property name="title" translatable="yes">Name</property>
                    <property name="show-apply-button">yes</property>
                  </object>
                </child>

                <child>
                  <object class="ScChRow">
                    <child><object class="MmControl"><property name="id">0x0c</property></object></child>
                  </object>
                </child>

              </object>
            </child>

            <child>
              <object class="AdwPreferencesGroup">

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Controller Groups</property>
                    <property name="target-page">Nkl1ControllerGroupsPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Transport Buttons</property>
                    <property name="target-page">Nkl1TransportButtonsPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

              </object>
            </child>

          </object>
        </property>
      </object>
    </property>
  </template>
</interface>
