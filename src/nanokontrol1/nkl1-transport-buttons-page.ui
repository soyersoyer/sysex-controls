<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  <template class="Nkl1TransportButtonsPage" parent="ScNavigationPage">
    <property name="title" translatable="yes">Transport Buttons</property>
    <property name="child">
      <object class="AdwToolbarView">
        <child type="top"><object class="AdwHeaderBar"/></child>
        <property name="content">
          <object class="ScPreferencesPage">

            <child>
              <object class="AdwPreferencesGroup">

                <child>
                  <object class="ScChRowGlob">
                    <child><object class="MmControl"><property name="id">0xe0</property></object></child>
                  </object>
                </child>

              </object>
            </child>

            <child>
              <object class="AdwPreferencesGroup">

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Rewind</property>
                    <property name="control-id-offset">0xe1</property>
                    <property name="target-page">Nkl1TransportButtonPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Play</property>
                    <property name="control-id-offset">0xe6</property>
                    <property name="target-page">Nkl1TransportButtonPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Fast-Forward</property>
                    <property name="control-id-offset">0xeb</property>
                    <property name="target-page">Nkl1TransportButtonPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

              </object>
            </child>

            <child>
              <object class="AdwPreferencesGroup">

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Loop</property>
                    <property name="control-id-offset">0xf0</property>
                    <property name="target-page">Nkl1TransportButtonPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Stop</property>
                    <property name="control-id-offset">0xf5</property>
                    <property name="target-page">Nkl1TransportButtonPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

                <child>
                  <object class="ScActionRow">
                    <property name="title" translatable="yes">Record</property>
                    <property name="control-id-offset">0xfa</property>
                    <property name="target-page">Nkl1TransportButtonPage</property>
                    <signal name="activated" handler="sc_action_nav_push"/>
                  </object>
                </child>

              </object>
            </child>

          </object>
        </property>
      </object>
    </property>

  </template>
</interface>
